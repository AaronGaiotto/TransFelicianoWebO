<%- include('../../layout/head') %>
<body class="app-body">
<%- include('../../layout/sidebar', { usuario, activePage }) %>
<div class="main-wrapper" id="mainWrapper">
  <%- include('../../layout/header', { usuario, pageTitle: 'Manutenções' }) %>
  <main class="content-area">
    
    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
      <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="flash flash-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <div class="page-header">
      <div class="page-header-left">
        <h1 class="page-title"><i class="fas fa-tools"></i> Manutenções</h1>
        <p class="page-subtitle">Controle preventivo e corretivo da frota</p>
      </div>
      <div class="page-header-right">
        <a href="/manutencoes/nova" class="btn btn-primary">
          <i class="fas fa-plus"></i> Nova Manutenção
        </a>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-body">
        <% if (!manutencoes || manutencoes.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-tools"></i>
            <p>Nenhuma manutenção registrada.</p>
          </div>
        <% } else { %>
          <table class="dash-table">
            <thead>
              <tr>
                <th>Caminhão</th>
                <th>Tipo</th>
                <th>Data</th>
                <th>Quilometragem</th>
                <th>Valor</th>
                <th>Status</th>
                <th style="text-align: center;">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% manutencoes.forEach(m => { %>
                <tr>
                  <td>
                    <span class="badge" style="background:var(--bg-lighter); color:var(--text-primary); border:1px solid var(--border);"><%= m.placa %></span>
                  </td>
                  <td>
                    <% if((m.tipo||'').toLowerCase() === 'preventiva') { %>
                      <i class="fas fa-shield-alt" style="color:var(--primary); margin-right:4px;"></i> Preventiva
                    <% } else { %>
                      <i class="fas fa-wrench" style="color:var(--amber); margin-right:4px;"></i> Corretiva
                    <% } %>
                  </td>
                  <td>
                    <% 
                      const d = m.data_manutencao || m.data_realizacao;
                      if(d) { 
                    %>
                      <%= new Date(d).toLocaleDateString('pt-BR') %>
                    <% } else { %> — <% } %>
                  </td>
                  <td><%= Number(m.quilometragem || m.km_realizacao || 0).toLocaleString('pt-BR') %> km</td>
                  <td><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(m.valor || m.custo || 0) %></td>
                  <td>
                    <% 
                      let badgeClass = 'secondary';
                      const st = (m.status || '').toLowerCase();
                      if (st === 'concluída' || st === 'concluida') badgeClass = 'success';
                      else if (st === 'em execução' || st === 'em execucao') badgeClass = 'warning';
                      else if (st === 'agendada') badgeClass = 'info';
                    %>
                    <span class="badge badge-<%= badgeClass %>"><%= m.status %></span>
                  </td>
                  <td style="text-align: center; white-space: nowrap;">
                    <a href="/manutencoes/<%= m.id %>" class="btn-action view" title="Detalhes"><i class="fas fa-eye"></i></a>
                    <a href="/manutencoes/<%= m.id %>/editar" class="btn-action edit" title="Editar"><i class="fas fa-edit"></i></a>
                    <form action="/manutencoes/<%= m.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Tem certeza que deseja excluir esta manutenção?');">
                      <button type="submit" class="btn-action delete" title="Excluir"><i class="fas fa-trash-alt"></i></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </main>
</div>

<style>
  .btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    margin: 0 2px;
    color: var(--text-secondary);
    background: var(--bg);
    transition: var(--transition);
    border: 1px solid var(--border);
  }
  .btn-action:hover { color: #fff; border-color: transparent; }
  .btn-action.view:hover { background: var(--primary); }
  .btn-action.edit:hover { background: var(--amber); }
  .btn-action.delete:hover { background: var(--red); }
</style>

<script src="/js/main.js"></script>
</body>
</html>
