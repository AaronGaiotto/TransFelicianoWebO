<%- include('../../layout/head') %>
<body class="app-body">
<%- include('../../layout/sidebar', { usuario, activePage }) %>
<div class="main-wrapper" id="mainWrapper">
  <%- include('../../layout/header', { usuario, pageTitle: rota ? 'Editar Rota' : 'Nova Rota' }) %>
  <main class="content-area">

    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="flash flash-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <div class="page-header">
      <div class="page-header-left">
        <h1 class="page-title"><i class="fas fa-route"></i> <%= rota ? 'Editar Rota' : 'Nova Rota' %></h1>
      </div>
      <div class="page-header-right">
        <a href="/rotas" class="btn" style="border: 1px solid var(--border);"><i class="fas fa-arrow-left"></i> Voltar</a>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-body" style="padding: 24px;">
        <form action="<%= rota ? '/rotas/' + rota.id + '?_method=PUT' : '/rotas' %>" method="POST">
          
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Origem *</label>
              <input type="text" name="origem" class="form-control" value="<%= rota ? rota.origem : '' %>" required placeholder="Ex: São Paulo - SP">
            </div>

            <div class="form-group">
              <label class="form-label">Destino *</label>
              <input type="text" name="destino" class="form-control" value="<%= rota ? rota.destino : '' %>" required placeholder="Ex: Rio de Janeiro - RJ">
            </div>

            <div class="form-group">
              <label class="form-label">Caminhão *</label>
              <select name="caminhao_id" class="form-control" required>
                <option value="">Selecione o Caminhão</option>
                <% if (caminhoes && caminhoes.length > 0) { %>
                  <% caminhoes.forEach(c => { %>
                    <option value="<%= c.id %>" <%= (rota && parseInt(rota.caminhao_id) === c.id) ? 'selected' : '' %>>
                      <%= c.placa %> — <%= c.marca %> <%= c.modelo %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Motorista *</label>
              <select name="motorista_id" class="form-control" required>
                <option value="">Selecione o Motorista</option>
                <% if (motoristas && motoristas.length > 0) { %>
                  <% motoristas.forEach(m => { %>
                    <option value="<%= m.id %>" <%= (rota && parseInt(rota.motorista_id) === m.id) ? 'selected' : '' %>>
                      <%= m.nome %> (CPF: <%= m.cpf %>)
                    </option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <div class="form-group">
              <label class="form-label">Data de Saída *</label>
              <% 
                let dSaida = '';
                if (rota && rota.data_saida) {
                  dSaida = rota.data_saida.substring(0, 16);
                }
              %>
              <input type="datetime-local" name="data_saida" class="form-control" value="<%= dSaida %>" required>
            </div>

            <div class="form-group">
              <label class="form-label">Data de Chegada Prevista/Real</label>
              <% 
                let dChegada = '';
                if (rota && rota.data_chegada) {
                  dChegada = rota.data_chegada.substring(0, 16);
                }
              %>
              <input type="datetime-local" name="data_chegada" class="form-control" value="<%= dChegada %>">
            </div>

            <div class="form-group">
              <label class="form-label">Valor do Frete (R$) *</label>
              <input type="number" step="0.01" name="valor_frete" class="form-control" value="<%= rota ? rota.valor_frete : '' %>" required min="0.01" placeholder="0.00">
            </div>

            <div class="form-group">
              <label class="form-label">Status</label>
              <select name="status" class="form-control">
                <% const currentStatus = rota ? (rota.status || '').toLowerCase() : 'planejada'; %>
                <option value="Planejada" <%= currentStatus === 'planejada' ? 'selected' : '' %>>Planejada</option>
                <option value="Em Andamento" <%= currentStatus === 'em andamento' ? 'selected' : '' %>>Em Andamento</option>
                <option value="Concluída" <%= currentStatus === 'concluída' || currentStatus === 'concluida' ? 'selected' : '' %>>Concluída</option>
                <option value="Cancelada" <%= currentStatus === 'cancelada' ? 'selected' : '' %>>Cancelada</option>
              </select>
            </div>

            <div class="form-group" style="grid-column: 1 / -1;">
              <label class="form-label">Observações</label>
              <textarea name="observacoes" class="form-control" rows="3" placeholder="Informações adicionais sobre a rota..."><%= rota ? rota.observacoes : '' %></textarea>
            </div>
          </div>

          <div style="margin-top: 24px; text-align: right; border-top: 1px solid var(--border-light); padding-top: 20px;">
            <a href="/rotas" class="btn" style="margin-right: 12px; border: 1px solid var(--border);">Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvar Rota</button>
          </div>
        </form>
      </div>
    </div>

  </main>
</div>

<style>
  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
  }
  .form-control {
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    transition: var(--transition);
    background: var(--bg);
    font-family: inherit;
  }
  .form-control:focus {
    outline: none;
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(26,86,219,.1);
  }
  textarea.form-control {
    resize: vertical;
  }
</style>

<script src="/js/main.js"></script>
</body>
</html>
