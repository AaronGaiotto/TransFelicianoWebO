<%- include('../../layout/head') %>
<body class="app-body">
<%- include('../../layout/sidebar', { usuario, activePage }) %>
<div class="main-wrapper" id="mainWrapper">
  <%- include('../../layout/header', { usuario, pageTitle: 'Rotas' }) %>
  <main class="content-area">
    
    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
      <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="flash flash-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <div class="page-header">
      <div class="page-header-left">
        <h1 class="page-title"><i class="fas fa-route"></i> Rotas</h1>
        <p class="page-subtitle">Acompanhamento e gestão de viagens</p>
      </div>
      <div class="page-header-right">
        <a href="/rotas/nova" class="btn btn-primary">
          <i class="fas fa-plus"></i> Nova Rota
        </a>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-body">
        <% if (!rotas || rotas.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-route"></i>
            <p>Nenhuma rota cadastrada.</p>
          </div>
        <% } else { %>
          <table class="dash-table">
            <thead>
              <tr>
                <th>Origem / Destino</th>
                <th>Motorista</th>
                <th>Caminhão</th>
                <th>Valor Frete</th>
                <th>Status</th>
                <th style="text-align: center;">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% rotas.forEach(r => { %>
                <tr>
                  <td>
                    <strong><%= r.origem %></strong>
                    <br><small><i class="fas fa-arrow-right" style="color:var(--text-muted); font-size:10px; margin:0 4px;"></i> <%= r.destino %></small>
                  </td>
                  <td><%= r.motorista_nome %></td>
                  <td><span class="badge" style="background:var(--bg-lighter); color:var(--text-primary); border:1px solid var(--border);"><%= r.placa %></span></td>
                  <td><%= new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(r.valor_frete || 0) %></td>
                  <td>
                    <% 
                      let badgeClass = 'secondary';
                      const st = (r.status || '').toLowerCase();
                      if (st === 'concluída' || st === 'concluida') badgeClass = 'success';
                      else if (st === 'em andamento') badgeClass = 'warning';
                      else if (st === 'cancelada') badgeClass = 'danger';
                      else badgeClass = 'info';
                    %>
                    <span class="badge badge-<%= badgeClass %>"><%= r.status %></span>
                  </td>
                  <td style="text-align: center; white-space: nowrap;">
                    <a href="/rotas/<%= r.id %>" class="btn-action view" title="Detalhes"><i class="fas fa-eye"></i></a>
                    <a href="/rotas/<%= r.id %>/editar" class="btn-action edit" title="Editar"><i class="fas fa-edit"></i></a>
                    <form action="/rotas/<%= r.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Tem certeza que deseja excluir esta rota?');">
                      <button type="submit" class="btn-action delete" title="Excluir"><i class="fas fa-trash-alt"></i></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </main>
</div>

<style>
  .btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    margin: 0 2px;
    color: var(--text-secondary);
    background: var(--bg);
    transition: var(--transition);
    border: 1px solid var(--border);
  }
  .btn-action:hover { color: #fff; border-color: transparent; }
  .btn-action.view:hover { background: var(--primary); }
  .btn-action.edit:hover { background: var(--amber); }
  .btn-action.delete:hover { background: var(--red); }
</style>

<script src="/js/main.js"></script>
</body>
</html>
