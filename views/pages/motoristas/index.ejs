<%- include('../../layout/head') %>
<body class="app-body">
<%- include('../../layout/sidebar', { usuario, activePage }) %>
<div class="main-wrapper" id="mainWrapper">
  <%- include('../../layout/header', { usuario, pageTitle: 'Motoristas' }) %>
  <main class="content-area">
    
    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
      <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="flash flash-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <div class="page-header">
      <div class="page-header-left">
        <h1 class="page-title"><i class="fas fa-id-card"></i> Motoristas</h1>
        <p class="page-subtitle">Cadastro e gerenciamento de motoristas</p>
      </div>
      <div class="page-header-right">
        <a href="/motoristas/novo" class="btn btn-primary">
          <i class="fas fa-plus"></i> Novo Motorista
        </a>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-body">
        <% if (!motoristas || motoristas.length === 0) { %>
          <div class="empty-state">
            <i class="fas fa-id-card"></i>
            <p>Nenhum motorista cadastrado.</p>
          </div>
        <% } else { %>
          <table class="dash-table">
            <thead>
              <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>Telefone</th>
                <th>CNH</th>
                <th>Status</th>
                <th style="text-align: center;">Ações</th>
              </tr>
            </thead>
            <tbody>
              <% motoristas.forEach(m => { %>
                <tr>
                  <td><strong><%= m.nome %></strong></td>
                  <td><%= m.cpf %></td>
                  <td><%= m.telefone || '—' %></td>
                  <td><%= m.numero_cnh || m.cnh || '—' %> <small>Venc: <%= m.validade_cnh ? new Date(m.validade_cnh).toLocaleDateString('pt-BR') : (m.cnh_validade ? new Date(m.cnh_validade).toLocaleDateString('pt-BR') : '—') %></small></td>
                  <td>
                    <span class="badge badge-<%= (m.status||'').toLowerCase() === 'ativo' ? 'success' : (m.status||'').toLowerCase() === 'inativo' ? 'secondary' : 'warning' %>">
                      <%= m.status %>
                    </span>
                  </td>
                  <td style="text-align: center; white-space: nowrap;">
                    <a href="/motoristas/<%= m.id %>" class="btn-action view" title="Detalhes"><i class="fas fa-eye"></i></a>
                    <a href="/motoristas/<%= m.id %>/editar" class="btn-action edit" title="Editar"><i class="fas fa-edit"></i></a>
                    <form action="/motoristas/<%= m.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Tem certeza que deseja excluir este motorista?');">
                      <button type="submit" class="btn-action delete" title="Excluir"><i class="fas fa-trash-alt"></i></button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </main>
</div>

<style>
  .btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    margin: 0 2px;
    color: var(--text-secondary);
    background: var(--bg);
    transition: var(--transition);
    border: 1px solid var(--border);
  }
  .btn-action:hover { color: #fff; border-color: transparent; }
  .btn-action.view:hover { background: var(--primary); }
  .btn-action.edit:hover { background: var(--amber); }
  .btn-action.delete:hover { background: var(--red); }
</style>

<script src="/js/main.js"></script>
</body>
</html>
