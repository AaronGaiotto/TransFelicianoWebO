<%- include('../../layout/head') %>
<body class="app-body">
<%- include('../../layout/sidebar', { usuario, activePage }) %>
<div class="main-wrapper" id="mainWrapper">
  <%- include('../../layout/header', { usuario, pageTitle: motorista ? 'Editar Motorista' : 'Novo Motorista' }) %>
  <main class="content-area">

    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="flash flash-danger"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <div class="page-header">
      <div class="page-header-left">
        <h1 class="page-title"><i class="fas fa-id-card"></i> <%= motorista ? 'Editar Motorista' : 'Novo Motorista' %></h1>
      </div>
      <div class="page-header-right">
        <a href="/motoristas" class="btn" style="border: 1px solid var(--border);"><i class="fas fa-arrow-left"></i> Voltar</a>
      </div>
    </div>

    <div class="dash-card">
      <div class="dash-card-body" style="padding: 24px;">
        <form action="<%= motorista ? '/motoristas/' + motorista.id + '?_method=PUT' : '/motoristas' %>" method="POST">
          
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Nome *</label>
              <input type="text" name="nome" class="form-control" value="<%= motorista ? motorista.nome : '' %>" required>
            </div>

            <div class="form-group">
              <label class="form-label">CPF *</label>
              <input type="text" name="cpf" class="form-control" value="<%= motorista ? motorista.cpf : '' %>" required placeholder="000.000.000-00">
            </div>

            <div class="form-group">
              <label class="form-label">Telefone</label>
              <input type="text" name="telefone" class="form-control" value="<%= motorista ? motorista.telefone : '' %>" placeholder="(00) 00000-0000">
            </div>

            <div class="form-group">
              <label class="form-label">Número da CNH *</label>
              <input type="text" name="numero_cnh" class="form-control" value="<%= motorista ? (motorista.numero_cnh || motorista.cnh || '') : '' %>" required>
            </div>

            <div class="form-group">
              <label class="form-label">Validade da CNH *</label>
              <% 
                let data_v = '';
                if (motorista) {
                  const v = motorista.validade_cnh || motorista.cnh_validade;
                  if (v) data_v = v.substring(0, 10);
                }
              %>
              <input type="date" name="validade_cnh" class="form-control" value="<%= data_v %>" required>
            </div>

            <div class="form-group">
              <label class="form-label">Status</label>
              <select name="status" class="form-control">
                <% const currentStatus = motorista ? (motorista.status || '').toLowerCase() : 'ativo'; %>
                <option value="Ativo" <%= currentStatus === 'ativo' ? 'selected' : '' %>>Ativo</option>
                <option value="Afastado" <%= currentStatus === 'afastado' ? 'selected' : '' %>>Afastado</option>
                <option value="Inativo" <%= currentStatus === 'inativo' ? 'selected' : '' %>>Inativo</option>
              </select>
            </div>
          </div>

          <div style="margin-top: 24px; text-align: right; border-top: 1px solid var(--border-light); padding-top: 20px;">
            <a href="/motoristas" class="btn" style="margin-right: 12px; border: 1px solid var(--border);">Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Salvar Motorista</button>
          </div>
        </form>
      </div>
    </div>

  </main>
</div>

<style>
  .form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .form-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
  }
  .form-control {
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    transition: var(--transition);
    background: var(--bg);
  }
  .form-control:focus {
    outline: none;
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(26,86,219,.1);
  }
</style>

<script src="/js/main.js"></script>
</body>
</html>
